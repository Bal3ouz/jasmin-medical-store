# Append to /etc/caddy/Caddyfile on the Hetzner host.
# DNS already wildcarded for *.data.ghdevlab.com → 188.245.96.6, so Caddy can
# issue Let's Encrypt certs as soon as it reads these blocks.

jasmin.data.ghdevlab.com {
    reverse_proxy localhost:4000
    encode gzip zstd
}

team.jasmin.data.ghdevlab.com {
    reverse_proxy localhost:4001
    encode gzip zstd
}
