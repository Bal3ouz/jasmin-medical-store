# Append to /etc/caddy/Caddyfile on the Hetzner host.
# Caddy will provision Let's Encrypt certs automatically once the A records
# in GoDaddy point jasminmedical.store and team.jasminmedical.store at
# 188.245.96.6.

jasminmedical.store, www.jasminmedical.store {
    reverse_proxy localhost:4000
    encode gzip zstd
}

team.jasminmedical.store {
    reverse_proxy localhost:4001
    encode gzip zstd
}
