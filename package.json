{
  "name": "jasmin-medical-store",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.0",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "bun --filter @jasmin/db generate",
    "db:migrate": "bun --filter @jasmin/db migrate",
    "db:seed": "bun --filter @jasmin/db seed",
    "db:seed:extended": "bun --filter @jasmin/db seed:extended",
    "db:seed:demo-staff": "bun --filter @jasmin/db seed:demo-staff",
    "db:upload-images": "bun --filter @jasmin/db upload-images",
    "demo:up": "supabase start && bun run db:migrate && bun run db:seed:extended && bun run db:seed:demo-staff && bun run db:upload-images && echo '\\n✓ demo ready — run `bun dev` and login at http://localhost:3001 with admin@jasmin.tn / Demo1234!'",
    "demo:down": "supabase stop",
    "demo:reset": "supabase db reset && bun run db:migrate && bun run db:seed:extended && bun run db:seed:demo-staff && bun run db:upload-images",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "turbo": "2.3.3",
    "typescript": "5.7.2"
  }
}
